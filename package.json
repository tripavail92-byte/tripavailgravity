{
  "name": "tripavail",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server.mjs",
    "dev": "turbo run dev",
    "build": "turbo run build --force",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:run-remote": "node scripts/run-remote-sql-file.mjs",
    "db:sql:remote": "node scripts/run-remote-sql-file.mjs",
    "db:finance:health": "node scripts/finance-health-report.mjs",
    "db:test:deposit-policy:remote": "node scripts/run-remote-sql-file.mjs --file supabase/tests/operator_tour_deposit_policy_test.sql",
    "db:test:payout-cycle": "node scripts/test-payout-cycle.mjs",
    "db:test:payouts:remote": "node scripts/run-remote-sql-file.mjs --file supabase/tests/operator_payout_batch_rpc_test.sql",
    "worker:payouts": "node scripts/run-operator-payout-worker.mjs",
    "worker:payouts:auto-settle": "node scripts/run-operator-payout-worker.mjs --auto-settle"
  },
  "dependencies": {
    "@vis.gl/react-google-maps": "^1.7.1",
    "react-error-boundary": "^6.1.1",
    "serve": "^14.2.5",
    "sirv": "^2.0.4"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.93.3",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/google.maps": "^3.58.1",
    "@types/pg": "^8.16.0",
    "pg": "^8.17.2",
    "stripe": "^15.12.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.3"
  }
}